# Backend Environment Variables
# Copy this file to .env and fill in production values

# Database Configuration
# Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/izoneweb

# Security - MUST be changed in production!
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change_me_to_a_secure_random_key_at_least_32_characters

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10

# Admin Credentials - MUST be changed in production!
ADMIN_USERNAME=admin@gmail.com
ADMIN_PASSWORD=admin123
ADMIN_RECOVERY_EMAIL=umar.izonetech@gmail.com

# SMTP Password Reset Email
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=umar.izonetech@gmail.com
SMTP_PASSWORD=rfuwtcprkjfvepyt
SMTP_FROM_EMAIL=umar.izonetech@gmail.com
SMTP_FROM_NAME=iZone Technologies
SMTP_USE_TLS=true
PASSWORD_RESET_CODE_EXPIRE_MINUTES=5

# CORS Configuration
# Local development example:
# ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
# Production example:
# ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
ALLOWED_ORIGINS=
# Debug Mode (set to false in production)
DEBUG=true
